{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"files": {
		"ignoreUnknown": true,
		"includes": ["gui/frontend/src/**"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"overrides": [
		{
			"includes": ["gui/frontend/src/**"],
			"linter": {
				"rules": {
					"style": {
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noExplicitAny": "off",
						"noArrayIndexKey": "off"
					},
					"a11y": {
						"noLabelWithoutControl": "off"
					},
					"complexity": {
						"noImportantStyles": "off"
					}
				}
			}
		}
	],
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
